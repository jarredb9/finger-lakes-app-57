{
  "repos": [
    {
      "repoId": "winery-visit-planner",
      "rootPath": "/app",
      "ignore": [
        "**/node_modules/**",
        "**/dist/**",
        "**/.next/**",
        "**/build/**",
        "**/.git/**",
        "**/coverage/**",
        "**/node_modules",
        "**/out/**",
        "**/build",
        "**/npm-debug.log*",
        "**/yarn-debug.log*",
        "**/yarn-error.log*",
        "**/.pnpm-debug.log*",
        "**/.env*",
        "**/.vercel",
        "**/.vercel/**",
        "**/*.tsbuildinfo",
        "**/next-env.d.ts",
        "**/next-env.d.ts/**",
        "**/.gemini/*",
        "**/.adal/**",
        "**/.agent/**",
        "**/.agents/**",
        "**/.augment/**",
        "**/.claude/**",
        "**/.codebuddy/**",
        "**/.commandcode/**",
        "**/.continue/**",
        "**/.cortex/**",
        "**/.crush/**",
        "**/.factory/**",
        "**/.goose/**",
        "**/.iflow/**",
        "**/.junie/**",
        "**/.kilocode/**",
        "**/.kiro/**",
        "**/.kode/**",
        "**/.mcpjam/**",
        "**/.mux/**",
        "**/.neovate/**",
        "**/.openhands/**",
        "**/.pi/**",
        "**/.pochi/**",
        "**/.qoder/**",
        "**/.qwen/**",
        "**/.roo/**",
        "**/.trae/**",
        "**/.vibe/**",
        "**/.windsurf/**",
        "**/.zencoder/**",
        "**/skills/**",
        "**/skills-lock.json",
        "**/skills-lock.json/**",
        "**/.cgcignore",
        "**/.cgcignore/**",
        "**/.env.local",
        "**/.env.local/**",
        "**/test-results/**",
        "**/playwright-report/**",
        "**/blob-report/**",
        "**/playwright/.cache/**",
        "**/playwright/.auth/**",
        "**/.cache/*",
        "**/.pki/*",
        "**/*.log",
        "**/public/sw.js",
        "**/public/sw.js/**",
        "**/public/workbox-*.js",
        "**/public/worker-*.js",
        "**/.next-docs/**",
        "**/.npm/**",
        "**/.playwright-mcp/**",
        "**/.config/**",
        "**/mcp.json",
        "**/mcp.json/**"
      ],
      "languages": [
        "js",
        "sh",
        "ts",
        "tsx"
      ],
      "maxFileBytes": 2000000
    }
  ],
  "dbPath": "/app/sdlmcp.sqlite",
  "policy": {
    "maxWindowLines": 180,
    "maxWindowTokens": 1400,
    "requireIdentifiers": true,
    "allowBreakGlass": true
  },
  "redaction": {
    "enabled": true,
    "includeDefaults": true,
    "patterns": []
  },
  "indexing": {
    "concurrency": 8,
    "enableFileWatching": true,
    "maxWatchedFiles": 25000
  },
  "slice": {
    "defaultMaxCards": 60,
    "defaultMaxTokens": 12000,
    "edgeWeights": {
      "call": 1,
      "import": 0.6,
      "config": 0.8
    }
  }
}